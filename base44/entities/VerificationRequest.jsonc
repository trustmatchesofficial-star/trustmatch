{
  "name": "VerificationRequest",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "selfie_url": {
      "type": "string"
    },
    "id_photo_url": {
      "type": "string"
    },
    "id_document_url": {
      "type": "string",
      "description": "Photo of passport/ID document submitted during verification. Required \u2014 no verification request can be created without it."
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewing",
        "approved",
        "rejected",
        "pending_review",
        "flagged_fraud"
      ],
      "default": "pending"
    },
    "review_note": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "user_id",
    "selfie_url",
    "id_document_url",
    "status"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}