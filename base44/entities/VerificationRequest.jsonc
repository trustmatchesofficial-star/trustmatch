{
  "name": "VerificationRequest",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "selfie_url": {
      "type": "string"
    },
    "id_photo_url": {
      "type": "string"
    },
    "id_document_url": {
      "type": "string",
      "description": "Photo of passport/ID document submitted during verification."
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewing",
        "approved",
        "rejected",
        "pending_review",
        "flagged_fraud"
      ],
      "default": "pending"
    },
    "review_note": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "user_id",
    "selfie_url",
    "status"
  ]
}